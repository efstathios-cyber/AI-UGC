{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "src/server/server.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/src/server/server.ts" },
    { "src": "/storage/(.*)", "dest": "/src/server/server.ts" },
    { "src": "/create", "dest": "/public/create.html" },
    { "src": "/library", "dest": "/public/library.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
