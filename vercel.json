{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/dist/server/server.js" },
    { "src": "/storage/(.*)", "dest": "/dist/server/server.js" },
    { "src": "/create", "dest": "/create.html" },
    { "src": "/library", "dest": "/library.html" },
    { "handle": "filesystem" }
  ]
}
